# Test-Environment — wird von vitest automatisch geladen (vor .env) durch src/test-setup.ts.
# Dieses File muss auf jeder Umgebung angelegt werden, wo `npm test` läuft, um die Live-DB
# vor Test-Artefakten zu schützen. Ist via .gitignore vom Repo ausgeschlossen.
#
# Separate Test-DB mit identischem Schema:
#   CREATE DATABASE reise_test OWNER reise;
#   for f in migrations/*.sql; do psql -U reise -d reise_test -f "$f"; done

DATABASE_URL=postgres://reise:PASSWORD@localhost:5432/reise_test
JWT_SECRET=test_secret_at_least_32_characters_long
JWT_EXPIRES_IN=1h
