    "react-native-maps": "^1.20.1",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
